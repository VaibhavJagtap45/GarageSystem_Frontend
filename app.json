{
  "expo": {
    "name": "GarageSystem",
    "slug": "GarageSystem",
    "version": "1.2.0",
    "orientation": "portrait",
    "scheme": "GarageSystem",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.Aapno.garageSystem",
      "buildNumber": "1",
      "infoPlist": {
        "NSContactsUsageDescription": "garageSystem uses your contacts to quickly add customers to your garage records.",
        "NSPhotoLibraryUsageDescription": "garageSystem needs access to your photo library to upload your garage logo.",
        "NSCameraUsageDescription": "garageSystem uses the camera to capture your garage logo photo."
      }
    },
    "android": {
      "package": "com.Aapno.garageSystem",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#1D9E75",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "garageSystem needs access to your photos to upload a garage logo.",
          "cameraPermission": "garageSystem uses the camera to capture your garage logo."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "garageSystem uses your contacts to quickly add customers."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "owner": "jrpant_45",
    "extra": {
      "apiBaseUrl": "https://aapno-garage-backend.onrender.com/api/v1/",
      "eas": {
        "projectId": "68484391-db33-44b5-b820-640198bb98af"
      }
    }
  }
}
