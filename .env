# Expo only inlines env vars prefixed with EXPO_PUBLIC_ into the JS bundle.
# This file is for LOCAL DEV ONLY — production reads from app.json -> extra.apiBaseUrl
# so that EAS builds are deterministic and don't depend on .env being present.

# ── Development (local) ────────────────────────────────────────────
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.105:4000/api/v1/

# ── Production override (optional) ─────────────────────────────────
# Leave commented to use the value from app.json -> extra.apiBaseUrl.
EXPO_PUBLIC_API_BASE_URL=https://aapno-garage-backend.onrender.com/api/v1/
